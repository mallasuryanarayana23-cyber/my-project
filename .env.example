# SkillMap Environment Variables
# In production, these should be set in your cloud provider (AWS/GCP/Supabase)

# PostGIS-enabled PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/skillmap?schema=public"

# Secret for JWT signing (jose)
JWT_SECRET="skillmap-premium-super-secret-key-2026"

# Node Env
NODE_ENV="development"
